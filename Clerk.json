{
  "name": "RASA_Clerk_Stub",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "clerk-log",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "clerk-trigger",
      "name": "Webhook: Receive Log",
      "type": "n8n-nodes-base.webhook",
