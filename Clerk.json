      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [450, 300],
      "credentials": { "postgres": { "id": "RASA_CLERK_DB" } }
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { 'status': 'logged', 'role': 'clerk' } }}",
        "options": {}
      },
      "id": "clerk-response",
      "name": "Respond Success",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [650, 300]
    }
  ],
  "connections": {
    "Webhook: Receive Log": { "main": [[{ "node": "Write to DB (Deep Capture)", "type": "main", "index": 0 }]] },
    "Write to DB (Deep Capture)": { "main": [[{ "node": "Respond Success", "type": "main", "index": 0 }]] }
  }
