{
  "name": "RASA_Fabric_Active_Registry",
  "nodes": [
    {
      "parameters": {},
      "id": "fabric-trigger",
      "name": "On Registry Request",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [250, 300],
      "notesInFlow": true,
      "notes": "RASA-044: Active Registry Entry Point.\nTriggered by Genesis via 'Execute Workflow' node."
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO rasa_public.execution_event (execution_id, role, task_type, status) VALUES (gen_random_uuid(), 'fabric', 'agent_registration', 'complete');",
        "options": {}
      },
      "id": "log-registration",
      "name": "Log Registration",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [450, 300],
      "credentials": {
        "postgres": {
          "id": "DUMMY_POSTGRES_CRED",
          "name": "RASA Clerk DB"
        }
      },
      "notesInFlow": true,
      "notes": "RASA-002: Deep Capture.\nLogs the successful registration of agents to Postgres."
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ { 'status': 'registered', 'message': 'Agents received via Genesis' } }}",
        "options": {}
      },
      "id": "respond-webhook",
      "name": "Respond Success",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [650, 300]
    }
  ],
  "connections": {
    "On Registry Request": {
      "main": [[{ "node": "Log Registration", "type": "main", "index": 0 }]]
    },
    "Log Registration": {
      "main": [[{ "node": "Respond Success", "type": "main", "index": 0 }]]
    }
  }
}
